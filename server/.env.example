# --- Core ---
NODE_ENV=production
PORT=4000
DATABASE_URL=postgres://ffpro:ffpro_password@postgres:5432/ffpro
PGSSL=false
SESSION_SECRET=replace_with_a_long_random_string

# Encrypts each user's synced financial data at the application layer before
# it's stored in Postgres. Must be base64 for exactly 32 bytes. Generate with:
#   openssl rand -base64 32
# Losing this key makes all synced data permanently unreadable — back it up
# somewhere safe (a password manager or secrets store), separately from the DB.
DATA_ENCRYPTION_KEY=replace_with_output_of_openssl_rand_-base64_32

# Number of reverse-proxy hops between the browser and this process. Default
# assumes host Nginx (TLS) -> docker "web" Nginx -> backend. See src/index.js.
TRUST_PROXY_HOPS=2

# Where to send the browser back to after OAuth completes.
FRONTEND_URL=https://your-domain.com

# --- Google (Google Cloud Console -> APIs & Services -> Credentials) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://your-domain.com/api/auth/google/callback

# --- Facebook (Meta for Developers -> My Apps) ---
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_CALLBACK_URL=https://your-domain.com/api/auth/facebook/callback

# --- Apple (Apple Developer -> Certificates, Identifiers & Profiles) ---
APPLE_CLIENT_ID=com.yourcompany.ffpro.web
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY_PATH=/run/secrets/apple_private_key.p8
APPLE_CALLBACK_URL=https://your-domain.com/api/auth/apple/callback
