# Encrypts each user's synced financial data at the application layer before
# it's stored in Postgres. Back this up somewhere safe and separate from the
# DB (password manager / secrets vault) — if it's lost, all synced data
# becomes permanently unreadable, by design.
DATA_ENCRYPTION_KEY=uPo1oppFZppr/sKNgEcYKT4lJV22XXWueHGTm9gfPzY=

# browser -> Nginx Proxy Manager (TLS, hop 1) -> this container's nginx (hop 2) -> backend
TRUST_PROXY_HOPS=2

FRONTEND_URL=https://ffpro.v79sl.duckdns.org

# --- Google (Google Cloud Console -> APIs & Services -> Credentials) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
